<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <FrameLayout
            android:id="@+id/avatarContainer"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/tvProfileAvatar"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:gravity="center"
                android:text="A"
                android:textColor="@color/bg_dark"
                android:textSize="40sp"
                android:textStyle="bold"
                android:background="@color/neon_green" />

            <ImageView
                android:id="@+id/ivProfilePicture"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:gravity="center"
                android:text="\u270E"
                android:textColor="@color/bg_dark"
                android:textSize="14sp"
                android:background="@color/neon_cyan" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"
            android:text="SARFIT Athlete"
            android:textColor="@color/neon_cyan"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/gradient_card"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStreakDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/neon_green"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day Streak \uD83D\uDD25"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/gradient_card"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/tvTotalDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/neon_cyan"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Workouts"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:padding="16dp"
            android:text="Log out"
            android:textColor="#FF4444"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/gradient_card" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/developer_credit"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>
